<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Base application theme -->
    <style name="Theme.LEIFLIX" parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <!-- Primary brand color -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Status bar visible + transparente -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>

    </style>

    <!-- ✅ Splash Screen personalizado (sin errores) -->
    <style name="Theme.LEIFLIX.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Fondo negro -->
        <item name="android:windowBackground">@color/black</item>
        <item name="android:statusBarColor">@android:color/black</item>
    </style>

</resources>
